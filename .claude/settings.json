{
  "permissions": {
    "allow": [
      "Bash(npm *)", "Bash(npx *)", "Bash(git *)", "Bash(ls *)",
      "Bash(mkdir *)", "Bash(node *)", "Bash(tsc *)", "Bash(jq *)",
      "Bash(gh *)", "Bash(cat *)", "Bash(echo *)", "Bash(grep *)",
      "Bash(find *)", "Bash(cp *)", "Bash(mv *)", "Bash(chmod *)",
      "Bash(curl *)", "Bash(kill *)", "Bash(ps *)",
      "Read", "Edit", "Write", "Glob", "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)", "Bash(rm -rf ~)", "Bash(sudo *)",
      "Read(.env*)", "Read(**/credentials*)", "Read(**/*secret*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/chimp-pick/.claude/hooks/check-quality.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/chimp-pick/.claude/hooks/check-commercial-quality.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/chimp-pick/.claude/hooks/summarize-context.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/chimp-pick/.claude/hooks/check-careful.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
