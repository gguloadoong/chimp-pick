{
  "name": "chimp-pick",
  "version": "0.1.0",
  "private": true,
  "description": "침팬지픽 — 주식/코인 UP/DOWN 예측 배틀 게임",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "lint:web": "npm run lint --workspace=apps/web",
    "lint:api": "npm run lint --workspace=apps/api",
    "test:web": "npm run test --workspace=apps/web",
    "test:api": "npm run test --workspace=apps/api"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
