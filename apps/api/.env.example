# Database
DATABASE_URL=postgresql://chimppick:chimppick@localhost:5432/chimppick

# TimescaleDB (가격 데이터용)
TIMESCALE_URL=postgresql://chimppick:chimppick@localhost:5433/chimppick_ts

# Redis
REDIS_URL=redis://localhost:6379

# JWT — access token (단기)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=1d

# JWT — refresh token (별도 시크릿으로 access 토큰 노출 시에도 refresh 보호)
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=4000
