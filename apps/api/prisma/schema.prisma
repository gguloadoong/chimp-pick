generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  nickname     String   @unique
  password     String?
  avatarLevel  Int      @default(1)
  bananaCoins  Int      @default(100) // 하위 호환 유지, 다음 스프린트에서 제거
  freeCoins    Int      @default(100) // 무료 획득 코인 (예측 참여 전용)
  paidCoins    Int      @default(0)   // IAP 구매 코인 (코스메틱 전용)
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  predictions   Prediction[]
  stats         UserStats?
  transactions  Transaction[]
  iapReceipts   IapReceipt[]
  streakInfo    DailyStreak?
  dailyMissions DailyMission[]
}

model DailyStreak {
  id            String    @id @default(cuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  maxStreak     Int       @default(0)
  lastCheckinAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model DailyMission {
  id          String    @id @default(cuid())
  userId      String
  date        String    // YYYY-MM-DD (KST)
  type        String    // FIRST_PREDICT, THREE_PREDICTS, SHARE
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  reward      Int       @default(10)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, type])
  @@index([userId, date])
}

model UserStats {
  id               String @id @default(cuid())
  userId           String @unique
  totalPredictions Int    @default(0)
  wins             Int    @default(0)
  losses           Int    @default(0)
  winRate          Float  @default(0)
  currentStreak    Int    @default(0)
  maxStreak        Int    @default(0)

  user User @relation(fields: [userId], references: [id])
}

model Prediction {
  id         String   @id @default(cuid())
  userId     String
  symbol     String
  direction  String   // UP or DOWN
  timeframe  String   // 1m, 5m, 1h, 1d
  entryPrice Float
  exitPrice  Float?
  betAmount  Int
  result     String   @default("PENDING") // PENDING, WIN, LOSE
  reward     Int?
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  expiresAt  DateTime

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId, createdAt])
  @@index([result])
  @@index([expiresAt])
}

model Transaction {
  id               String   @id @default(cuid())
  userId           String
  type             String   // PURCHASE, DAILY_BONUS, AD_REWARD, PREDICTION_SPEND, PREDICTION_REWARD, COSMETIC_SPEND, REFERRAL_BONUS
  coinType         String   @default("FREE") // FREE | PAID
  amount           Int
  balanceAfter     Int
  predictionId     String?
  iapTransactionId String?  // IapReceipt 연결 (IAP 구매 시)
  description      String?
  createdAt        DateTime @default(now())

  prediction Prediction? @relation(fields: [predictionId], references: [id], onDelete: Restrict)
  user       User        @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type])
}

model IapReceipt {
  id                    String    @id @default(cuid())
  userId                String
  platform              String    // APPLE | GOOGLE
  productId             String    // com.chimppick.coins.pack1 등
  transactionId         String    @unique
  originalTransactionId String?
  purchaseToken         String?
  environment           String    // PRODUCTION | SANDBOX
  status                String    // PENDING | VERIFIED | REJECTED | REFUNDED
  coinAmount            Int
  priceKrw              Int
  receiptData           String    @db.Text
  verifiedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([platform, productId])
  @@index([status])
}

model IapProduct {
  id         String   @id @default(cuid())
  productId  String   @unique // com.chimppick.coins.pack1
  platform   String           // APPLE | GOOGLE | ALL
  name       String           // "바나나 50개"
  coinAmount Int
  priceKrw   Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model PriceCandle {
  id        String   @id @default(cuid())
  symbol    String
  timeframe String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  timestamp DateTime

  @@unique([symbol, timeframe, timestamp])
  @@index([symbol, timestamp])
}
